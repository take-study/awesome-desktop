{
  "TODO": {
    "prefix": "todo",
    "body": "$LINE_COMMENT $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE TODO:"
  },
  "HACK": {
    "prefix": "hack",
    "body": "$LINE_COMMENT $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE HACK:"
  },
  "FIX": {
    "prefix": "fix",
    "body": "$LINE_COMMENT $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE FIX:"
  },
  "NOTE": {
    "prefix": "NOTE",
    "body": "$LINE_COMMENT $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE NOTE:"
  },
  "TEST": {
    "prefix": "test",
    "body": "$LINE_COMMENT $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE TEST:"
  },
  "WARN": {
    "prefix": "warn",
    "body": "$LINE_COMMENT $CURRENT_YEAR-$CURRENT_MONTH-$CURRENT_DATE WARN:"
  },
  "launch": {
    "prefix": "launch",
    "body": [
      "{",
      "  \"version\": \"0.2.0\",",
      "  \"configurations\": [{",
      "  \"name\": \"Launch\",",
      "  \"type\": \"$1\",",
      "  \"request\": \"launch\",",
      "  \"cwd\": \"${2:$3{workspaceFolder}}\",",
      "  \"program\": \"${4:$2}/$5\",",
      "  \"console\": \"internalConsole\"",
      "  }]",
      "}"
    ]
  }
}
