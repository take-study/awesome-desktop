[Unit]
Description=Use fuzzel as polkit agent
After=graphical-session.target

[Service]
Type=exec
# Repurpose XDG Autostart filtering
ExecCondition=/lib/systemd/systemd-xdg-autostart-condition "wlroots:sway:Wayfire:labwc:Hyprland:Niri:niri" ""
ExecStart=%h/.local/bin/fuzzel-polkit-agent
Restart=on-failure
Slice=app-graphical.slice
RestartSec=2s

[Install]
WantedBy=graphical-session.target
